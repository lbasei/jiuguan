# Gemini（服务端专用，禁止加 VITE_ 前缀，禁止暴露到前端）
# 本地 .env / Vercel 环境变量都只配服务端可读变量。
GEMINI_API_KEY=
# 可选模型；免费层对新用户建议 gemini-flash-latest
# GEMINI_MODEL=gemini-flash-latest
# 重要：Node 不会自动走系统 VPN。本机 Clash 混合端口示例：
# HTTPS_PROXY=http://127.0.0.1:7897
# GEMINI_HTTPS_PROXY=http://127.0.0.1:7897
# 可选：自定义 Gemini API 根地址（自建网关/联调）
# GEMINI_API_BASE=https://generativelanguage.googleapis.com

# 旧版前端直连 LLM 已停用（key 会暴露）。保留变量名仅兼容旧文档，请勿再填。
# VITE_LLM_API_KEY=
# VITE_LLM_MODEL=deepseek-v4-flash
# VITE_LLM_BASE_URL=/deepseek

# Adventure 深链（展会）：换域名只改这里，不要在页面里写死。
# 空着时 collect 默认 http://localhost:3000（本地 data-collection）。
# 线上填 Production，例如 https://your-collection.vercel.app（不要末尾斜杠）。
VITE_COLLECT_BASE_URL=
# 可选：酒馆自己的线上根地址，以后「返回酒馆」用；可先空着。
VITE_TAVERN_BASE_URL=
# 活动 campaign，写入 collect 的 query；默认 adventurex-2026。
VITE_ADVENTURE_CAMPAIGN=adventurex-2026

# 语音转写配置。dev 默认走 Vite 代理 /openai，key 可填 OPENAI_API_KEY 或 VITE_OPENAI_API_KEY。
OPENAI_API_KEY=
VITE_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Seedance / 火山方舟视频动效。不要把真实 ark key 提交到 GitHub。
# SEEDANCE_API_URL 以你控制台的视频生成接口为准；后端会作为代理调用。
SEEDANCE_API_KEY=
SEEDANCE_API_URL=
SEEDANCE_MODEL=seedance-1-0-lite

# Supabase（邮箱密码登录 + 业务数据）
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Existing shared projects may use these aliases; the backend accepts either pair.
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 手机验证码登录（已停用，保留变量供旧文档参考）。
# 真实取验证码必须先在腾讯云短信控制台申请：短信应用 SDKAppID、短信签名、短信模板。
# 模板内容示例：「验证码为{1}，5分钟内有效。」模板变量只有一个 {1}。
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou

# 或者接任何自有短信网关，后端会 POST { phone, code, template }。
SMS_API_URL=
SMS_API_KEY=
SMS_TEMPLATE=life-kitchen-login

# 种种主题邀请码管理。线上生成/查看邀请码时需要在请求头带 x-admin-key。
INVITE_ADMIN_KEY=

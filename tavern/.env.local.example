# 真·LLM 自然语言解析配置（当前接 DeepSeek，OpenAI 兼容）。
# 复制为 .env（或 .env.local）并填 key 即启用；不填则自动降级本地规则解析，demo 不崩。
VITE_LLM_API_KEY=
VITE_LLM_MODEL=deepseek-v4-flash
# 可选：覆盖 base url；dev 默认走 Vite 代理 /deepseek 绕 CORS
# VITE_LLM_BASE_URL=/deepseek

# Adventure 深链（展会）：换域名只改这里，不要在页面里写死。
# 空着时 collect 默认 http://localhost:3000（本地 data-collection）。
# 线上填 Production，例如 https://your-collection.vercel.app（不要末尾斜杠）。
# 使用同一域名路径代理时填 same-origin，自定义域名和 vercel.app 都会保持当前来源。
VITE_COLLECT_BASE_URL=
# 可选：酒馆自己的线上根地址，以后「返回酒馆」用；可先空着。
VITE_TAVERN_BASE_URL=
# 活动 campaign，写入 collect 的 query；默认 adventurex-2026。
VITE_ADVENTURE_CAMPAIGN=adventurex-2026

# 展位现场流程：酒馆入口会依次跳转到联名游园与承诺池；两项都需指向实际部署地址。
# VITE_COLLECT_BASE_URL=https://your-collection.vercel.app
# VITE_TAVERN_BASE_URL=https://your-tavern.vercel.app
# 单域名代理：
# VITE_COLLECT_BASE_URL=same-origin
# VITE_TAVERN_BASE_URL=same-origin

# 语音转写配置。dev 默认走 Vite 代理 /openai，key 可填 OPENAI_API_KEY 或 VITE_OPENAI_API_KEY。
OPENAI_API_KEY=
VITE_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Seedance / 火山方舟视频动效。不要把真实 ark key 提交到 GitHub。
# SEEDANCE_API_URL 以你控制台的视频生成接口为准；后端会作为代理调用。
SEEDANCE_API_KEY=
SEEDANCE_API_URL=
SEEDANCE_MODEL=seedance-1-0-lite

# 邮箱密码登录（走 Supabase Auth，与 data-collection 同一项目即可）。
# 本地可直接复用 data-collection/.env.local 里的三项。
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 种种主题邀请码管理。线上生成/查看邀请码时需要在请求头带 x-admin-key。
INVITE_ADMIN_KEY=
